<RelativeLayout android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#AA000000"
    android:layout_height="match_parent"
    android:clickable="true"
    android:id="@+id/event_menu"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:id="@+id/event_menu_sub_button_holder">
        <android.support.design.widget.FloatingActionButton
            android:id="@+id/event_fab_picture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:src="@drawable/ic_camera"
            app:backgroundTint="#E65100"
            app:pressedTranslationZ="12dp"
            app:fabSize="mini"

            android:layout_alignParentBottom="true"
            android:layout_alignParentRight="true"
            android:layout_marginRight="184dp"
            android:layout_marginBottom="76dp" />

        <android.support.design.widget.FloatingActionButton
            android:id="@+id/event_fab_gallery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:src="@drawable/ic_gallery"
            app:backgroundTint="#EF6C00"
            app:pressedTranslationZ="12dp"
            app:fabSize="mini"

            android:layout_alignParentBottom="true"
            android:layout_alignParentRight="true"
            android:layout_marginRight="141dp"
            android:layout_marginBottom="141dp"/>

        <android.support.design.widget.FloatingActionButton
            android:id="@+id/event_fab_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:src="@drawable/ic_event"
            app:backgroundTint="#F57C00"
            android:tint="#000000"
            app:pressedTranslationZ="12dp"
            app:fabSize="mini"

            android:layout_alignParentBottom="true"
            android:layout_alignParentRight="true"
            android:layout_marginRight="76dp"
            android:layout_marginBottom="184dp"/>
    </RelativeLayout>
</RelativeLayout>
