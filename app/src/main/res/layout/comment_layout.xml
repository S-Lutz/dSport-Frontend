<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView android:layout_width="match_parent"
    android:layout_marginTop="@dimen/activity_horizontal_margin"
    android:layout_height="wrap_content"
    android:background="@android:drawable/dialog_holo_light_frame"
    android:id="@+id/postView"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <android.support.v7.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentRight="true"
            android:scaleType="centerCrop"
            android:src="@drawable/namebar"
            android:id="@+id/comment_namebar"
            android:fitsSystemWindows="true"
            android:cropToPadding="false"/>

        <android.support.v7.widget.AppCompatTextView
            style="@style/header"
            android:layout_alignTop="@+id/comment_namebar"
            android:layout_alignLeft="@+id/comment_namebar"
            android:layout_alignRight="@+id/comment_namebar"
            android:layout_alignBottom="@+id/comment_namebar"
            android:layout_margin="8dp"
            android:textColor="#666666"
            android:gravity="bottom|left"
            android:id="@+id/comment_username"/>

        <android.support.v7.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_below="@id/comment_username"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="16dp"
            android:adjustViewBounds="true"
            android:visibility="gone"
            android:id="@+id/comment_picture"/>
        <android.support.v7.widget.AppCompatTextView
            style="@style/body"
            android:layout_below="@id/comment_picture"
            android:id="@+id/comment_text"
            />
        <android.support.v7.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/comment_text"
            android:drawableLeft="@drawable/ic_like"
            android:id="@+id/comment_like_count"
            android:padding="@dimen/activity_horizontal_margin"
            android:textAppearance="@style/TextAppearance.AppCompat.Body2"
            android:gravity="center_vertical"/>
        <View
            android:layout_below="@id/comment_like_count"
            android:layout_width="match_parent"
            android:id="@+id/devider"
            android:layout_height="1dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            style="@style/devider"/>
        <android.support.v7.widget.AppCompatTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/comment_date"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="16dp"
            android:layout_alignParentEnd="true"
            android:layout_below="@id/devider"/>
    </RelativeLayout>
</android.support.v7.widget.CardView>