<?xml version="1.0" encoding="utf-8"?>
<android.support.v4.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_create_event"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    tools:context="com.omgproduction.dsport_application.activities.main.CreateEventActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <android.support.v7.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:maxHeight="104dp"
            android:src="@drawable/default_profile"
            android:scaleType="centerCrop"
            android:id="@+id/create_event_picture"
            android:adjustViewBounds="true"/>
        <android.support.v7.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignTop="@+id/create_event_picture"
            android:layout_alignParentLeft="true"
            android:layout_alignRight="@+id/create_event_picture"
            android:layout_alignBottom="@+id/create_event_picture"
            android:scaleType="centerCrop"
            android:src="@drawable/post_overlay"
            android:fitsSystemWindows="true"
            android:cropToPadding="false"/>

        <android.support.v7.widget.AppCompatTextView
            style="@style/header"
            android:layout_below="@id/create_event_picture"
            android:layout_alignTop="@+id/create_event_picture"
            android:layout_alignParentLeft="true"
            android:layout_margin="8dp"
            android:textColor="#666666"
            android:layout_alignRight="@+id/create_event_picture"
            android:layout_alignBottom="@+id/create_event_picture"
            android:gravity="bottom|left"
            android:id="@+id/create_event_username"/>


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_alignBottom="@id/create_event_picture"
            android:layout_alignRight="@id/create_event_picture"
            android:layout_alignTop="@id/create_event_picture"
            android:weightSum="2">

            <android.support.v7.widget.AppCompatImageButton
                android:id="@+id/create_event_camera1_button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_margin="16dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_camera"
                android:layout_weight="1"
                android:layout_alignTop="@+id/create_event_username"
                android:layout_alignStart="@+id/create_event_gallery1_button" />

            <android.support.v7.widget.AppCompatImageButton
                android:id="@+id/create_event_gallery1_button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignBottom="@+id/create_event_picture"
                android:layout_alignRight="@+id/create_event_picture"
                android:layout_margin="16dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_gallery" />
        </LinearLayout>

        <android.support.design.widget.TextInputLayout
            style="@style/header"
            android:id="@+id/create_event_header_input_layout"
            android:layout_below="@id/create_event_picture"
            android:layout_margin="@dimen/activity_horizontal_margin">
            <android.support.v7.widget.AppCompatEditText
                style="@style/header"
                android:layout_below="@id/create_event_picture"
                android:gravity="center"
                android:maxLines="1"
                android:inputType="text|textAutoComplete|textAutoCorrect"
                android:hint="@string/create_event_header_hint"
                android:background="@android:color/transparent"
                android:id="@+id/create_event_title"/>
        </android.support.design.widget.TextInputLayout>

        <android.support.v7.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_below="@id/create_event_header_input_layout"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="16dp"
            android:adjustViewBounds="true"
            android:visibility="gone"
            android:id="@+id/create_event_event_picture"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/create_event_button2_container"
            android:layout_below="@+id/create_event_event_picture"
            android:weightSum="2"
            android:layout_margin="16dp"
            android:orientation="horizontal">
            <android.support.v7.widget.AppCompatImageButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:id="@+id/create_event_camera2_button"
                android:layout_weight="1"
                android:src="@drawable/ic_camera"/>
            <android.support.v7.widget.AppCompatImageButton
                android:layout_width="match_parent"
                android:id="@+id/create_event_gallery2_button"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_gallery"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/event_date_container"
            android:layout_below="@id/create_event_button2_container"
            android:orientation="horizontal"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="16dp"
                android:layout_marginRight="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:tint="@color/colorPrimary"
                android:src="@android:drawable/ic_dialog_alert"/>

            <android.support.v7.widget.AppCompatTextView
                style="@style/body"
                android:transitionName="@string/transition_event_event_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="0dp"
                android:id="@+id/event_date_tv"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/event_location_container"
            android:layout_below="@id/event_date_container"
            android:orientation="horizontal"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="16dp"
                android:layout_marginRight="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:tint="@color/colorPrimary"
                android:src="@android:drawable/ic_dialog_map"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <android.support.v7.widget.AppCompatTextView
                    style="@style/body"
                    android:transitionName="@string/transition_event_location"
                    android:id="@+id/event_location_name_tv"
                    android:layout_gravity="center"
                    android:layout_margin="0dp">
                </android.support.v7.widget.AppCompatTextView>

                <android.support.v7.widget.AppCompatTextView
                    style="@style/body"
                    android:transitionName="@string/transition_event_location"
                    android:id="@+id/event_location_address_tv"
                    android:layout_gravity="center"
                    android:layout_margin="0dp">
                </android.support.v7.widget.AppCompatTextView>

            </LinearLayout>
        </LinearLayout>


        <android.support.design.widget.TextInputLayout
            style="@style/body"
            android:id="@+id/create_event_text_input_layout"
            android:layout_below="@id/event_location_container">
            <android.support.v7.widget.AppCompatEditText
                style="@style/body"
                android:layout_margin="0dp"
                android:background="@android:color/transparent"
                android:id="@+id/create_event_text"
                android:inputType="textMultiLine|textAutoComplete|textAutoCorrect"
                android:hint="@string/create_event_text_hint"
                />
        </android.support.design.widget.TextInputLayout>
        <android.support.design.widget.FloatingActionButton
            android:id="@+id/create_event_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:backgroundTint="@color/colorOkFab"
            android:layout_alignParentRight="true"
            android:layout_margin="16dp"
            android:layout_below="@+id/create_event_text_input_layout"
            android:src="@drawable/ic_ok" />

    </RelativeLayout>

</android.support.v4.widget.NestedScrollView>
