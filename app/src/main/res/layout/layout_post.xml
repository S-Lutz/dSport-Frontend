<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="wrap_content">
    
    <android.support.v7.widget.CardView
        android:layout_width="match_parent"
        android:layout_marginTop="@dimen/activity_horizontal_margin"
        android:layout_height="wrap_content"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:id="@+id/postView">
        <RelativeLayout
            android:layout_width="match_parent"
            android:id="@+id/post_relative_layout"
            android:layout_height="wrap_content">
            <android.support.v7.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:maxHeight="104dp"
                android:src="@drawable/default_profile"
                android:scaleType="centerCrop"
                android:transitionName="@string/transition_user_picture"
                android:id="@+id/post_picture"
                android:adjustViewBounds="true"/>
            <android.support.v7.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignTop="@+id/post_picture"
                android:transitionName="@string/transition_post_picture_overlay"
                android:id="@+id/post_picture_overlay"
                android:layout_alignParentLeft="true"
                android:layout_alignRight="@+id/post_picture"
                android:layout_alignBottom="@+id/post_picture"
                android:scaleType="centerCrop"
                android:src="@drawable/post_overlay"
                android:fitsSystemWindows="true"
                android:cropToPadding="false"/>

            <android.support.v7.widget.AppCompatTextView
                style="@style/header"
                android:layout_below="@id/post_picture"
                android:layout_alignTop="@+id/post_picture"
                android:layout_alignParentLeft="true"
                android:layout_margin="8dp"
                android:textColor="#666666"
                android:transitionName="@string/transition_post_username"
                android:layout_alignRight="@+id/post_picture"
                android:layout_alignBottom="@+id/post_picture"
                android:gravity="bottom|left"
                android:id="@+id/post_username"/>

            <android.support.v7.widget.AppCompatTextView
                style="@style/header"
                android:layout_below="@id/post_picture"
                android:gravity="center"
                android:transitionName="@string/transition_post_title"
                android:layout_margin="@dimen/activity_horizontal_margin"
                android:id="@+id/post_title"/>

            <android.support.v7.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_below="@id/post_title"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="16dp"
                android:adjustViewBounds="true"
                android:visibility="gone"
                android:id="@+id/post_post_picture"/>
            <android.support.v7.widget.AppCompatTextView
                style="@style/body"
                android:layout_below="@id/post_post_picture"
                android:transitionName="@string/transition_post_text"
                android:id="@+id/post_text"
                />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_below="@+id/post_text"
                android:weightSum="3"
                android:transitionName="@string/transition_post_buttons"
                android:layout_marginLeft="@dimen/activity_horizontal_margin"
                android:layout_marginRight="@dimen/activity_horizontal_margin"
                android:id="@+id/post_option_container"
                android:orientation="horizontal">
                <android.support.v7.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_like"
                    android:id="@+id/post_like_count"
                    android:paddingLeft="@dimen/activity_horizontal_margin"
                    android:paddingRight="@dimen/activity_horizontal_margin"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:gravity="center_vertical"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    style="@style/devider"/>
                <android.support.v7.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_comments"
                    android:id="@+id/post_comment_count"
                    android:paddingLeft="@dimen/activity_horizontal_margin"
                    android:paddingRight="@dimen/activity_horizontal_margin"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:gravity="center_vertical"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_below="@+id/post_create_action"
                    style="@style/devider"/>
                <android.support.v7.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_share"
                    android:id="@+id/post_share_count"
                    android:paddingLeft="@dimen/activity_horizontal_margin"
                    android:paddingRight="@dimen/activity_horizontal_margin"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:gravity="center_vertical"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:id="@+id/devider"
                android:layout_height="1dp"
                android:layout_below="@+id/post_option_container"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                style="@style/devider"/>
            <android.support.v7.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/post_date"
                android:transitionName="@string/transition_post_date"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="16dp"
                android:layout_alignParentEnd="true"
                android:layout_below="@id/devider"/>
        </RelativeLayout>
    </android.support.v7.widget.CardView>
</LinearLayout>