<?xml version="1.0" encoding="utf-8"?>
<!--CoordinatorLayout to make special things like SnackBars possible-->
<android.support.design.widget.CoordinatorLayout
    android:id="@+id/agb_layout"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">


    <!--Scrollable Main View with all Input or Output Fields-->
    <android.support.v4.widget.NestedScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_bg">

        <!--Layout to Controll Input and Outputfield-Positions-->
        <android.support.v7.widget.LinearLayoutCompat
            android:layout_width="fill_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:paddingTop="50dp">

            <!--dSport-Logo-->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="200dp"
                android:src="@drawable/logo" />

            <!--Hided Progress-Bar to show on loading Data-->
            <android.support.v4.widget.ContentLoadingProgressBar
                style="@style/Base.Widget.AppCompat.ProgressBar"
                android:layout_width="match_parent"
                android:id="@+id/progress_bar"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone" />

            <!--Header AGB-->
            <android.support.v7.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/agb"
                android:id="@+id/agb_header"
                android:textSize="@dimen/headline"/>

            <!--Header AGB-->
            <android.support.v7.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/agb_info"
                android:textSize="@dimen/subhead"/>

            <!--Header AGB-->
            <android.support.v7.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/agb_text"/>

            <!--Checkbox to Accept the AGB-->
            <android.support.v7.widget.AppCompatCheckBox
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/cb_agb"
                android:text="@string/agb_accept"/>

            <!--Button to start registration-->
            <Button
                android:id="@+id/btn_goon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorPrimary"
                android:text="@string/btn_goon"
                android:layout_marginTop="16dp"
                android:textColor="@android:color/white" />
        </android.support.v7.widget.LinearLayoutCompat>

    </android.support.v4.widget.NestedScrollView>

</android.support.design.widget.CoordinatorLayout>
