<?xml version="1.0" encoding="utf-8"?>


<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:mlns="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/error_dialog_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:text="Ooops... an error occured"
        mlns:layout_constraintEnd_toEndOf="parent"
        mlns:layout_constraintStart_toStartOf="parent"
        mlns:layout_constraintTop_toTopOf="parent" />


    <Button
        android:id="@+id/error_dialog_cacel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="112dp"
        android:layout_marginTop="8dp"
        android:text="CANCEL"
        mlns:layout_constraintStart_toStartOf="parent"
        mlns:layout_constraintTop_toBottomOf="@+id/error_dialog_text" />

    <Button
        android:id="@+id/error_dialog_retry"
        android:layout_width="87dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="88dp"
        android:layout_marginTop="8dp"
        android:text="RE TRY"
        mlns:layout_constraintEnd_toEndOf="parent"
        mlns:layout_constraintTop_toBottomOf="@+id/error_dialog_text" />


</android.support.constraint.ConstraintLayout>