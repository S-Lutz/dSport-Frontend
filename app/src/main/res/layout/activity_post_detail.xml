<?xml version="1.0" encoding="utf-8"?>

<android.support.v4.widget.SwipeRefreshLayout android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <android.support.v4.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="match_parent"
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <android.support.v7.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:maxHeight="104dp"
                android:src="@drawable/default_profile"
                android:scaleType="centerCrop"
                android:id="@+id/post_detail_picture"
                android:adjustViewBounds="true"/>
            <android.support.v7.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignTop="@+id/post_detail_picture"
                android:layout_alignParentLeft="true"
                android:layout_alignRight="@+id/post_detail_picture"
                android:layout_alignBottom="@+id/post_detail_picture"
                android:scaleType="centerCrop"
                android:src="@drawable/post_overlay"
                android:fitsSystemWindows="true"
                android:cropToPadding="false"/>

            <android.support.v7.widget.AppCompatTextView
                style="@style/header"
                android:layout_below="@id/post_detail_picture"
                android:layout_alignTop="@+id/post_detail_picture"
                android:layout_alignParentLeft="true"
                android:layout_margin="8dp"
                android:textColor="#666666"
                android:layout_alignRight="@+id/post_detail_picture"
                android:layout_alignBottom="@+id/post_detail_picture"
                android:gravity="bottom|left"
                android:id="@+id/post_detail_username"/>

            <android.support.v7.widget.AppCompatTextView
                style="@style/header"
                android:layout_below="@id/post_detail_picture"
                android:gravity="center"
                android:layout_margin="@dimen/activity_horizontal_margin"
                android:id="@+id/post_detail_title"/>

            <android.support.v7.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_below="@id/post_detail_title"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="16dp"
                android:adjustViewBounds="true"
                android:visibility="gone"
                android:id="@+id/post_detail_post_picture"/>
            <android.support.v7.widget.AppCompatTextView
                style="@style/body"
                android:layout_below="@id/post_detail_post_picture"
                android:id="@+id/post_text"
                />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_below="@+id/post_text"
                android:weightSum="3"
                android:layout_marginLeft="@dimen/activity_horizontal_margin"
                android:layout_marginRight="@dimen/activity_horizontal_margin"
                android:id="@+id/post_detail_option_container"
                android:orientation="horizontal">
                <android.support.v7.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_like"
                    android:id="@+id/post_detail_like_count"
                    android:paddingLeft="@dimen/activity_horizontal_margin"
                    android:paddingRight="@dimen/activity_horizontal_margin"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:gravity="center_vertical"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    style="@style/devider"/>
                <android.support.v7.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_comments"
                    android:id="@+id/post_detail_comment_count"
                    android:paddingLeft="@dimen/activity_horizontal_margin"
                    android:paddingRight="@dimen/activity_horizontal_margin"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:gravity="center_vertical"/>
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_below="@+id/post_detail_create_action"
                    style="@style/devider"/>
                <android.support.v7.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_share"
                    android:id="@+id/post_detail_share_count"
                    android:paddingLeft="@dimen/activity_horizontal_margin"
                    android:paddingRight="@dimen/activity_horizontal_margin"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:gravity="center_vertical"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:id="@+id/devider"
                android:layout_height="1dp"
                android:layout_below="@+id/post_detail_option_container"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                style="@style/devider"/>
            <android.support.v7.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/post_detail_date"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="16dp"
                android:layout_alignParentEnd="true"
                android:layout_below="@id/devider"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/post_detail_date"
                android:id="@+id/post_detail_like_layout"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    style="@style/sub_sub_header"
                    android:layout_height="wrap_content"
                    android:text="@string/show_likes"
                    android:padding="4dp"
                    android:layout_gravity="center"/>
                <android.support.v7.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:visibility="gone"
                    android:layout_height="wrap_content"
                    android:id="@+id/post_detail_like_recycler"/>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/post_detail_like_layout"
                android:id="@+id/post_detail_comment_layout"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/sub_sub_header"
                    android:text="@string/comments"
                    android:padding="4dp"
                    android:layout_gravity="center"/>
                <android.support.v7.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/post_detail_comment_recycler"/>
            </LinearLayout>
        </RelativeLayout>

    </android.support.v4.widget.NestedScrollView>
</android.support.v4.widget.SwipeRefreshLayout>
