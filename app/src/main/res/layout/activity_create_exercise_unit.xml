<?xml version="1.0" encoding="utf-8"?>
<android.support.v4.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_create_exercise_unit"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    tools:context="com.omgproduction.dsport_application.activities.main.CreateExerciseUnitActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <android.support.v7.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:maxHeight="104dp"
            android:src="@drawable/default_profile"
            android:scaleType="centerCrop"
            android:id="@+id/create_exercise_unit_picture"
            android:adjustViewBounds="true"/>
        <android.support.v7.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignTop="@+id/create_exercise_unit_picture"
            android:layout_alignParentLeft="true"
            android:layout_alignRight="@+id/create_exercise_unit_picture"
            android:layout_alignBottom="@+id/create_exercise_unit_picture"
            android:scaleType="centerCrop"
            android:src="@drawable/post_overlay"
            android:fitsSystemWindows="true"
            android:cropToPadding="false"/>

        <android.support.v7.widget.AppCompatTextView
            style="@style/header"
            android:layout_below="@id/create_exercise_unit_picture"
            android:layout_alignTop="@+id/create_exercise_unit_picture"
            android:layout_alignParentLeft="true"
            android:layout_margin="8dp"
            android:textColor="#666666"
            android:layout_alignRight="@+id/create_exercise_unit_picture"
            android:layout_alignBottom="@+id/create_exercise_unit_picture"
            android:gravity="bottom|left"
            android:id="@+id/create_exercise_unit_username"/>

        <android.support.design.widget.TextInputLayout
            style="@style/header"
            android:id="@+id/create_exercise_unit_header"
            android:layout_below="@id/create_exercise_unit_picture"
            android:layout_margin="@dimen/activity_horizontal_margin">
            <TextView
                style="@style/header"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create a new Exercise Unit"/>

        </android.support.design.widget.TextInputLayout>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/create_exercise_unit_create_exercise_button"
            android:text="@string/create_new_exercise"
            android:layout_below="@id/create_exercise_unit_header"/>

        <LinearLayout
            android:id="@+id/exercise_unit_type_container"
            android:layout_below="@id/create_exercise_unit_create_exercise_button"
            android:orientation="horizontal"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginRight="16dp"
                android:text="Type"
                android:textStyle="bold" />

            <android.support.v7.widget.AppCompatSpinner
                android:id="@+id/exercise_unit_type_spinner"
                android:layout_below="@id/create_exercise_unit_picture"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <android.support.design.widget.FloatingActionButton
            android:id="@+id/create_exercise_unit_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:backgroundTint="@color/colorOkFab"
            android:layout_alignParentRight="true"
            android:layout_margin="16dp"
            android:layout_below="@+id/exercise_unit_type_container"
            android:src="@drawable/ic_ok" />

    </RelativeLayout>

</android.support.v4.widget.NestedScrollView>