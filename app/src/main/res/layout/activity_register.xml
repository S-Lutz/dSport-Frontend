<?xml version="1.0" encoding="utf-8"?>


<!--CoordinatorLayout to make special things like SnackBars possible-->
<android.support.design.widget.CoordinatorLayout
    android:id="@+id/register_layout"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">


    <!--Scrollable Main View with all Input or Output Fields-->
    <android.support.v4.widget.NestedScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_bg">

        <!--Layout to Controll Input and Outputfield-Positions-->
        <android.support.v7.widget.LinearLayoutCompat
            android:layout_width="fill_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:paddingTop="50dp">

            <!--dSport-Logo-->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="200dp"
                android:src="@drawable/logo" />

            <!--Hided Progress-Bar to show on loading Data-->
            <android.support.v4.widget.ContentLoadingProgressBar
                style="@style/Base.Widget.AppCompat.ProgressBar"
                android:layout_width="match_parent"
                android:id="@+id/progress_bar"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone" />

            <!--Container to make all Input-Fields Visible or Gone-->
            <android.support.v7.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:id="@+id/register_input_container"
                android:layout_height="wrap_content">

                <!--Header Registration-->
                <android.support.v7.widget.AppCompatTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/registration_header"
                    android:textSize="@dimen/headline"/>

                <!--Support Material-Design Text-Input-Layout with Error-Field and much more-->
                <android.support.design.widget.TextInputLayout
                    android:id="@+id/register_layout_username"
                    android:layout_width="match_parent"
                    android:paddingTop="20dp"
                    android:layout_height="wrap_content">

                    <!--Input for Username-->
                    <EditText
                        android:id="@+id/register_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_username"
                        android:singleLine="true" />
                </android.support.design.widget.TextInputLayout>

                <!--Support Material-Design Text-Input-Layout with Error-Field and much more-->
                <android.support.design.widget.TextInputLayout
                    android:id="@+id/register_layout_firstname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!--Input for Firstname-->
                    <EditText
                        android:id="@+id/register_firstname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_firstname"
                        android:singleLine="true" />
                </android.support.design.widget.TextInputLayout>

                <!--Support Material-Design Text-Input-Layout with Error-Field and much more-->
                <android.support.design.widget.TextInputLayout
                    android:id="@+id/register_layout_lastname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!--Input for Lastname-->
                    <EditText
                        android:id="@+id/register_lastname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_lastname"
                        android:singleLine="true" />
                </android.support.design.widget.TextInputLayout>

                <!--Support Material-Design Text-Input-Layout with Error-Field and much more-->
                <android.support.design.widget.TextInputLayout
                    android:id="@+id/register_layout_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!--Input for Email-->
                    <EditText
                        android:id="@+id/register_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_email"
                        android:inputType="textEmailAddress"
                        android:singleLine="true" />
                </android.support.design.widget.TextInputLayout>

                <!--Support Material-Design Text-Input-Layout with Error-Field and much more-->
                <android.support.design.widget.TextInputLayout
                    android:id="@+id/register_layout_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!--Input for Password-->
                    <EditText
                        android:id="@+id/register_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_password"
                        android:inputType="textPassword" />
                </android.support.design.widget.TextInputLayout>

                <!--Support Material-Design Text-Input-Layout with Error-Field and much more-->
                <android.support.design.widget.TextInputLayout
                    android:id="@+id/register_layout_password_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!--Input for Password Confirmation-->
                    <EditText
                        android:id="@+id/register_password_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_password_confirm"
                        android:inputType="textPassword" />
                </android.support.design.widget.TextInputLayout>

                <!--Checkbox to Accept the AGB-->
                <android.support.v7.widget.AppCompatCheckBox
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/cb_agb"
                    android:text="@string/agb_accept"/>

                <!--Link o read the AGB-->
                <android.support.v7.widget.AppCompatTextView
                    android:id="@+id/tv_agb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/agb_link"
                    android:padding="5dp"
                    android:gravity="center"/>

                <!--Button to start registration-->
                <Button
                    android:id="@+id/btn_register"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/colorPrimary"
                    android:text="@string/btn_register"
                    android:layout_marginTop="16dp"
                    android:textColor="@android:color/white" />

                <!--Link to Login-->
                <android.support.v7.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp"
                    android:id="@+id/signup_link"
                    android:textColor="@color/colorAccent"
                    android:text="@string/signup_link"/>
            </android.support.v7.widget.LinearLayoutCompat>

        </android.support.v7.widget.LinearLayoutCompat>

    </android.support.v4.widget.NestedScrollView>
</android.support.design.widget.CoordinatorLayout>
