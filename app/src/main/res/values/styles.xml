<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <item name="android:windowContentTransitions" tools:targetApi="lollipop">true</item>
    </style>



    <style name="AppTheme.Base" parent="Base.Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <item name="android:windowContentTransitions" tools:targetApi="lollipop">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="AppTheme.Base" />

    <style name="AppTheme.PopupOverlay" parent="AppTheme.Base" />



    <style name="AppTheme.NoActionBar" parent="AppTheme.Base">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>


    <style name="AppTheme.ActionBar" parent="AppTheme.Base">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">true</item>
    </style>




    <style name="header" parent="@android:style/TextAppearance.Large">
        <item name="android:textColor">#000000</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:textStyle">italic</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="sub_header"  parent="@android:style/TextAppearance.Medium">
        <item name="android:textColor">#000000</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_margin">@dimen/activity_horizontal_margin</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="sub_sub_header"  parent="@android:style/TextAppearance.DeviceDefault.Small">
        <item name="android:textColor">#000000</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_margin">@dimen/activity_horizontal_margin</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="body"  parent="@android:style/TextAppearance.DeviceDefault">
        <item name="android:textColor">#000000</item>
        <item name="android:layout_margin">@dimen/activity_horizontal_margin</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="devider">
        <item name="android:background">@android:color/darker_gray</item>
    </style>
</resources>